{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["debugger/**/*.ts", "debugger/**/*.js", "extensions/**/*.js"],
  "exclude": ["debugger/docs.ts", "debugger/vite.config.ts"]
}
