{
  "plugins": [],
  "recurseDepth": 10,
  "opts": {
    "recurse": true,
    "destination": "./docs/debugger/",
    "readme": "debugger/README.md"
  },
  "source": {
    "include": ["debugger/docs.ts"],
    "includePattern": ".+\\.ts$",
    "excludePattern": "node_modules"
  },
  "sourceType": "module",
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "templates": {
    "default": {
      "layoutFile": "./docs/assets/custom.debugger.tmpl",
      "includeDate": false
    },
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
