{
  "plugins": [],
  "recurseDepth": 10,
  "opts": {
    "recurse": true,
    "destination": "./docs/extensions/"
  },
  "source": {
    "include": [
      "extensions/src/audio",
      "extensions/src/controls",
      "extensions/src/display",
      "extensions/README.md"
    ],
    "includePattern": ".+\\.ts$",
    "excludePattern": "node_modules"
  },
  "sourceType": "module",
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "templates": {
    "default": {
      "layoutFile": "./docs/assets/custom.extensions.tmpl",
      "includeDate": false
    },
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
